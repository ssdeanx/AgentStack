{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "libReplacement": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 0,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noUncheckedSideEffectImports": false,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "vitest.config.ts",
    "mdx-components.tsx",
    "eslint.config.js",
    "prettier.config.js",
    "postcss.config.mjs",
    "next.config.ts",
    "components.json",
    "instrumentation.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx",
    "styles/**/*.ts",
    "styles/**/*.tsx",
    "ui/**/*.ts",
    "ui/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "convex/**/*.ts",
    "convex/**/*.tsx",
    "convex/**/*.d.ts",
    "convex/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".mastra",
    ".github",
    ".cursor",
    ".kilocode",
    ".next",
    "coverage",
    "docs",
    "memory-bank",
    "memories",
    "public",
    "scripts",
    "tests",
    "node_modules/@crawlee/http/internals/http-crawler.d.ts",
    "node_modules/@mdx-js/loader/index.d.cts",
    "logs",
    "data",
    "assets",
    "corpus",
    "thoughts"
  ],
  "watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/.next",
      "**/.mastra",
      "dist",
      "coverage",
      "docs",
      "memory-bank",
      "memories",
      "public"
    ],
    "excludeFiles": [
      "node_modules/@mdx-js/loader/index.d.cts"
    ]
  }
}
